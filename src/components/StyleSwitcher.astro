---
const modes = [
  { value: 'comfort', label: 'Comfort' },
  { value: 'focus', label: 'Focus' },
];
---

<div class="style-switcher" data-reading-switcher>
  <span class="style-switcher__label">Read</span>
  <div class="style-switcher__buttons" role="radiogroup" aria-label="Choose reading mode">
    {
      modes.map((mode) => (
        <button
          type="button"
          class="style-switcher__button"
          data-reading-option={mode.value}
          aria-label={`Use ${mode.label} reading mode`}
          aria-checked="false"
          role="radio"
          title={mode.label}
        >
          <span class="style-switcher__toggle-dot" aria-hidden="true"></span>
        </button>
      ))
    }
  </div>
</div>

<script is:inline>
  (() => {
    const themeStorageKey = 'astro-style-pack';
    const readingStorageKey = 'astro-reading-mode';
    const allowed = ['comfort', 'focus'];
    const root = document.documentElement;
    const normalize = (value) => (allowed.includes(value) ? value : 'comfort');
    const apply = (value) => {
      const mode = normalize(value);
      const buttons = Array.from(document.querySelectorAll('[data-reading-option]'));
      root.setAttribute('data-theme-pack', 'neo-retro');
      root.setAttribute('data-theme', 'light');
      root.setAttribute('data-reading-mode', mode);
      root.style.colorScheme = 'light';
      buttons.forEach((button) => {
        const active = button.dataset.readingOption === mode;
        button.setAttribute('aria-checked', String(active));
        button.toggleAttribute('data-active', active);
      });
      try {
        localStorage.setItem(themeStorageKey, 'neo-retro');
        localStorage.setItem(readingStorageKey, mode);
        localStorage.setItem('starlight-theme', 'light');
      } catch {}
    };
    let initial = 'comfort';
    try {
      initial = normalize(localStorage.getItem(readingStorageKey));
    } catch {}
    apply(initial);
    document.querySelectorAll('[data-reading-option]').forEach((button) => {
      if (button.dataset.styleSwitcherBound === 'true') return;
      button.dataset.styleSwitcherBound = 'true';
      button.addEventListener('click', () => apply(button.dataset.readingOption));
    });
  })();
</script>
