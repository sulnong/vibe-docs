<label class="reading-toggle" data-reading-switcher>
  <span class="reading-toggle__label">Theme</span>
  <input
    class="reading-toggle__checkbox"
    type="checkbox"
    data-reading-toggle
    aria-label="Use night reading tone"
  />
  <span class="reading-toggle__container" aria-hidden="true">
    <span class="reading-toggle__scenery">
      <span class="reading-toggle__spark"></span>
      <span class="reading-toggle__spark"></span>
      <span class="reading-toggle__spark"></span>
      <span class="reading-toggle__cloud"></span>
      <span class="reading-toggle__cloud"></span>
    </span>
    <span class="reading-toggle__orb"></span>
  </span>
</label>

<script is:inline>
  (() => {
    const themeStorageKey = 'astro-style-pack';
    const readingStorageKey = 'astro-reading-mode';
    const allowed = ['day', 'night'];
    const root = document.documentElement;
    const normalize = (value) => (allowed.includes(value) ? value : 'day');
    const apply = (value) => {
      const mode = normalize(value);
      const toggles = Array.from(document.querySelectorAll('[data-reading-toggle]'));
      root.setAttribute('data-theme-pack', 'neo-retro');
      root.setAttribute('data-theme', 'light');
      root.setAttribute('data-reading-mode', mode);
      root.style.colorScheme = mode === 'night' ? 'dark' : 'light';
      toggles.forEach((toggle) => {
        toggle.checked = mode === 'night';
      });
      try {
        localStorage.setItem(themeStorageKey, 'neo-retro');
        localStorage.setItem(readingStorageKey, mode);
        localStorage.setItem('starlight-theme', 'light');
      } catch {}
    };
    let initial = 'day';
    try {
      initial = normalize(localStorage.getItem(readingStorageKey));
    } catch {}
    apply(initial);
    document.querySelectorAll('[data-reading-toggle]').forEach((toggle) => {
      if (toggle.dataset.readingSwitcherBound === 'true') return;
      toggle.dataset.readingSwitcherBound = 'true';
      toggle.addEventListener('change', () => apply(toggle.checked ? 'night' : 'day'));
    });
  })();
</script>
