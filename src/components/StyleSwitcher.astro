---
const styles = [
  { value: 'base', label: 'Base', background: '#f6f8fb', accent: '#2563eb' },
  { value: 'neo-retro', label: 'Retro', background: '#fff7d6', accent: '#db2777' },
  { value: 'luminous', label: 'Luminous', background: '#06101a', accent: '#55c7ff' },
];
---

<div class="style-switcher" data-style-switcher>
  <span class="style-switcher__label">Theme</span>
  <div class="style-switcher__buttons" role="radiogroup" aria-label="Choose page theme">
    {
      styles.map((style) => (
        <button
          type="button"
          class="style-switcher__button"
          data-style-option={style.value}
          aria-label={`Use ${style.label} theme`}
          aria-checked="false"
          role="radio"
          title={style.label}
        >
          <span
            class="style-switcher__swatch"
            style={`--swatch-bg: ${style.background}; --swatch-accent: ${style.accent};`}
            aria-hidden="true"
          ></span>
        </button>
      ))
    }
  </div>
</div>

<script is:inline>
  (() => {
    const storageKey = 'astro-style-pack';
    const allowed = ['base', 'neo-retro', 'luminous'];
    const lightPacks = ['base', 'neo-retro'];
    const root = document.documentElement;
    const normalize = (value) => (allowed.includes(value) ? value : 'base');
    const apply = (value) => {
      const theme = normalize(value);
      const mode = lightPacks.includes(theme) ? 'light' : 'dark';
      const buttons = Array.from(document.querySelectorAll('[data-style-option]'));
      root.setAttribute('data-theme-pack', theme);
      root.setAttribute('data-theme', mode);
      root.style.colorScheme = mode;
      buttons.forEach((button) => {
        const active = button.dataset.styleOption === theme;
        button.setAttribute('aria-checked', String(active));
        button.toggleAttribute('data-active', active);
      });
      try {
        localStorage.setItem(storageKey, theme);
        localStorage.setItem('starlight-theme', mode);
      } catch {}
    };
    let initial = 'base';
    try {
      initial = normalize(localStorage.getItem(storageKey));
    } catch {}
    apply(initial);
    document.querySelectorAll('[data-style-option]').forEach((button) => {
      if (button.dataset.styleSwitcherBound === 'true') return;
      button.dataset.styleSwitcherBound = 'true';
      button.addEventListener('click', () => apply(button.dataset.styleOption));
    });
  })();
</script>
