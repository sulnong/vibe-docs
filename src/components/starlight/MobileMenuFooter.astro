---
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import StyleSwitcher from '../StyleSwitcher.astro';
---

<div class="mobile-preferences sl-flex">
  <div class="social-icons">
    <SocialIcons />
  </div>
  <StyleSwitcher />
  <LanguageSelect />
</div>

<style>
  @layer starlight.core {
    .social-icons {
      display: flex;
      margin-inline-end: auto;
      gap: 1rem;
      align-items: center;
      padding-block: 1rem;
    }

    .social-icons:empty {
      display: none;
    }

    .mobile-preferences {
      justify-content: space-between;
      flex-wrap: wrap;
      border-top: 1px solid var(--astro-global-border);
      column-gap: 1rem;
      row-gap: 0.75rem;
      padding: 0.75rem 0;
    }
  }
</style>
