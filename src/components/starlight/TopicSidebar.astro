---
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';

const TOPIC_SLUGS = [
  'astro',
  'hermes',
  'swarms',
  'awesome-skills',
  'china-economy',
  'china-ai',
  'china-industry',
  'china-society',
  'china-energy',
];
const HOST_TOPICS = new Map([
  ['astro.docxing.top', 'astro'],
  ['hermes.docxing.top', 'hermes'],
  ['hermes-agent.docxing.top', 'hermes'],
  ['swarms.docxing.top', 'swarms'],
  ['awesome-skills.docxing.top', 'awesome-skills'],
  ['china-economy.docxing.top', 'china-economy'],
  ['china-ai.docxing.top', 'china-ai'],
  ['china-industry.docxing.top', 'china-industry'],
  ['china-society.docxing.top', 'china-society'],
  ['china-energy.docxing.top', 'china-energy'],
]);

const { sidebar } = Astro.locals.starlightRoute;
const hostname = Astro.url.hostname.toLowerCase();
const pathname = Astro.url.pathname;
const topicFromHost = HOST_TOPICS.get(hostname);
const topicFromPath = TOPIC_SLUGS.find((slug) =>
  new RegExp(`/(?:en|zh)/${slug}(/|$)|/${slug}(/|$)`).test(pathname)
);
const currentTopic = topicFromHost ?? topicFromPath;

const filteredSidebar = currentTopic
  ? sidebar
      .filter((entry) => entryContainsTopic(entry, currentTopic))
      .map((entry) => normalizeTopicEntry(entry, currentTopic, pathname))
  : sidebar;

function entryContainsTopic(entry, topic) {
  if ('href' in entry && typeof entry.href === 'string') {
    return entry.href.includes(`/${topic}/`);
  }

  if ('entries' in entry && Array.isArray(entry.entries)) {
    return entry.entries.some((child) => entryContainsTopic(child, topic));
  }

  return false;
}

function normalizeTopicEntry(entry, topic, currentPathname) {
  if ('href' in entry && typeof entry.href === 'string') {
    const href = isRootChinaTopic(topic) ? stripInjectedLocale(entry.href, topic) : entry.href;
    return {
      ...entry,
      href,
      isCurrent: normalizePath(href) === normalizePath(currentPathname),
    };
  }

  if ('entries' in entry && Array.isArray(entry.entries)) {
    return {
      ...entry,
      entries: entry.entries.map((child) => normalizeTopicEntry(child, topic, currentPathname)),
    };
  }

  return entry;
}

function isRootChinaTopic(topic) {
  return topic.startsWith('china-');
}

function stripInjectedLocale(href, topic) {
  return href.replace(new RegExp(`^/(?:en|zh)/(${topic})(/|$)`), '/$1$2');
}

function normalizePath(path) {
  return path.endsWith('/') ? path : `${path}/`;
}
---

<SidebarPersister>
  <SidebarSublist sublist={filteredSidebar} />
</SidebarPersister>

<div class="md:sl-hidden">
  <MobileMenuFooter />
</div>
