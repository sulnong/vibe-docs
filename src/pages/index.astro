---
import '../styles/custom.css';
import StyleSwitcher from '../components/StyleSwitcher.astro';

const styleBootScript = `(() => {
  const root = document.documentElement;
  root.setAttribute('data-theme-pack', 'neo-retro');
  root.setAttribute('data-theme', 'light');
  root.style.colorScheme = 'light';
  try {
    localStorage.setItem('astro-style-pack', 'neo-retro');
    localStorage.setItem('starlight-theme', 'light');
  } catch {}
})();`;

const withBase = (path) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
const featured = [
  {
    title: "China's 15th Five-Year Plan, Explained",
    href: '/china-economy/china-15th-five-year-plan/',
    label: 'China Economy',
    text: 'A full policy map for China’s 2026-2030 cycle: new quality productive forces, AI, domestic demand, opening up, welfare, green transition, and security.',
  },
  {
    title: 'China 2026: The Reflation Turning Point',
    href: '/china-economy/china-2026-reflation-turning-point/',
    label: 'China Economy',
    text: 'A long-form explainer on China’s shift from deflation pressure toward selective reflation, and why property, AI, geopolitics, and debt now have to be read together.',
  },
  {
    title: 'Why DeepSeek V4 Looks Plain',
    href: '/china-ai/deepseek-v4-efficiency-strategy/',
    label: 'China AI',
    text: 'DeepSeek’s newest model is best read as an efficiency strategy: long context, lower inference cost, hardware optionality, and a quieter theory of AI power.',
  },
  {
    title: 'China’s Semiconductor Substitution Strategy',
    href: '/china-industry/china-semiconductor-substitution-strategy/',
    label: 'China Industry',
    text: 'A chip-industry explainer on why memory fabs, equipment validation, materials, and anchor customers matter for China’s semiconductor self-reliance push.',
  },
];
const readerPaths = [
  {
    title: 'Policy becomes concrete',
    text: 'National plans, ministries, firms, households, grids, and local governments are read together so abstract policy has real-world edges.',
  },
  {
    title: 'Chinese terms, plain English',
    text: 'Key phrases such as new quality productive forces, unified national market, and common prosperity are explained in their policy context.',
  },
  {
    title: 'Context before conclusion',
    text: 'Essays separate what the document says, what the data can show, and what remains uncertain before turning toward interpretation.',
  },
];
const coverage = [
  {
    title: 'Macro and balance sheets',
    text: 'Deflation, reflation, fiscal expansion, local debt, household confidence, property adjustment, and the policy trade-offs behind nominal growth.',
  },
  {
    title: 'Industry and capacity',
    text: 'EVs, solar, batteries, robotics, chemicals, equipment, exports, overcapacity debates, and where Chinese supply chains are gaining or losing leverage.',
  },
  {
    title: 'Technology infrastructure',
    text: 'AI investment, chips, data centers, memory, power demand, platform shifts, and the physical bottlenecks behind software narratives.',
  },
  {
    title: 'Energy and resources',
    text: 'Electricity, coal, oil, gas, grids, storage, strategic minerals, shipping routes, and the resource map underneath China’s industrial transition.',
  },
];
const routes = [
  {
    title: 'The 15th Plan cluster',
    href: '/china-economy/china-15th-five-year-plan/',
    label: 'Guide',
    text: 'A central map for the 2026-2030 policy cycle and the related essays on industry, AI, demand, welfare, security, energy, and culture.',
  },
  {
    title: 'AI, data, and compute',
    href: '/china-ai/ai-data-compute-15th-five-year-plan/',
    label: 'Technology',
    text: 'Why China’s AI agenda is about compute clusters, model efficiency, data resources, AI Plus applications, and governance.',
  },
  {
    title: 'Industrial upgrading',
    href: '/china-industry/new-quality-productive-forces-15th-five-year-plan/',
    label: 'Industry',
    text: 'How advanced manufacturing, future industries, supply-chain control, and technology self-reliance become one industrial strategy.',
  },
  {
    title: 'Demand, welfare, and confidence',
    href: '/china-economy/domestic-demand-15th-five-year-plan/',
    label: 'Society',
    text: 'A route into consumption, household security, services, income, mobility, and the policy problem of making demand feel durable.',
  },
];
const readerTools = [
  'A short answer up front for quick orientation.',
  'Definitions for policy terms that travel badly across languages.',
  'Tables, timelines, and source links when they make the argument easier to follow.',
  'Related reading paths that connect policy, companies, sectors, and social change.',
];
const hubs = [
  { name: 'China Economy', href: '/china-economy/' },
  { name: 'China AI', href: '/china-ai/' },
  { name: 'China Industry', href: '/china-industry/' },
  { name: 'China Society', href: '/china-society/' },
  { name: 'China Energy', href: '/china-energy/' },
];
const legacy = [
  { name: 'Astro', href: '/en/astro/' },
  { name: 'Awesome Skills', href: '/en/awesome-skills/' },
  { name: 'Hermes Agent', href: '/en/hermes/' },
  { name: 'Swarms', href: '/en/swarms/' },
];
---

<!doctype html>
<html lang="en" data-theme-pack="neo-retro" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>China Explained</title>
    <meta
      name="description"
      content="Deep English explainers on China’s economy, industry, technology, and energy."
    />
    <link rel="canonical" href="https://docxing.top/" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline set:html={styleBootScript}></script>
  </head>
  <body>
    <main class="home-shell">
      <nav class="home-topbar" aria-label="Home controls">
        <a class="home-brand" href="/">
          <img src="/logo.svg" alt="" width="34" height="34" />
          <span>China Explained</span>
        </a>
        <StyleSwitcher />
      </nav>

      <section class="home-hero" aria-labelledby="home-title">
        <p class="home-kicker">Deep English explainers</p>
        <h1 id="home-title" class="home-title">China, in context.</h1>
        <p class="home-summary">
          Long-form English essays on China’s economy, industry, technology, energy, society, and policy, built from high-signal Chinese sources for readers who want the full argument.
        </p>
        <div class="home-meta" aria-label="Site qualities">
          <span>China economy</span>
          <span>China AI</span>
          <span>Industrial policy</span>
          <span>Society and mobility</span>
          <span>Policy context</span>
        </div>
      </section>

      <section class="home-paths" aria-labelledby="coverage-title">
        <div class="section-heading section-heading--wide">
          <p class="home-kicker">Coverage map</p>
          <h2 id="coverage-title">The beat is China’s real economy.</h2>
        </div>
        <div class="path-grid path-grid--four">
          {coverage.map((item) => (
            <article class="path-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section aria-labelledby="featured-title">
        <div class="section-heading">
          <p class="home-kicker">Start here</p>
          <h2 id="featured-title">Begin with the strongest frames</h2>
        </div>
        <div class="topic-grid topic-grid--featured">
          {featured.map((item) => (
            <article class="topic-card topic-card--featured">
              <p class="topic-card__label">{item.label}</p>
              <h2>{item.title}</h2>
              <p>{item.text}</p>
              <div class="topic-card__actions">
                <a href={withBase(item.href)}>Read the essay</a>
                <a href={withBase(`/${item.label.toLowerCase().replace(' ', '-')}/`)}>Open topic hub</a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="home-paths" aria-labelledby="hubs-title">
        <div class="section-heading">
          <p class="home-kicker">Topic hubs</p>
          <h2 id="hubs-title">Five doors into the same China story</h2>
        </div>
        <div class="home-meta">
          {hubs.map((item) => <a href={withBase(item.href)}>{item.name}</a>)}
        </div>
      </section>

      <section class="home-paths" aria-labelledby="routes-title">
        <div class="section-heading section-heading--wide">
          <p class="home-kicker">Reading routes</p>
          <h2 id="routes-title">Follow systems, not the posting order.</h2>
        </div>
        <div class="topic-grid topic-grid--queue">
          {routes.map((item) => (
            <article class="topic-card topic-card--compact">
              <p class="topic-card__label">{item.label}</p>
              <h2>{item.title}</h2>
              <p>{item.text}</p>
              <div class="topic-card__actions">
                <a href={withBase(item.href)}>Open route</a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="home-paths" aria-labelledby="reader-paths-title">
        <div class="section-heading">
          <p class="home-kicker">How to read</p>
          <h2 id="reader-paths-title">Start with the question, then follow the system.</h2>
        </div>
        <div class="path-grid">
          {readerPaths.map((item) => (
            <article class="path-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="home-paths home-promise" aria-labelledby="promise-title">
        <div class="section-heading section-heading--wide">
          <p class="home-kicker">Reader tools</p>
          <h2 id="promise-title">Every essay should give you handles.</h2>
        </div>
        <ul class="promise-list">
          {readerTools.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section class="home-paths legacy-links" aria-labelledby="legacy-title">
        <div class="section-heading">
          <p class="home-kicker">Archive</p>
          <h2 id="legacy-title">Technical guides remain available</h2>
        </div>
        <div class="home-meta">
          {legacy.map((item) => <a href={withBase(item.href)}>{item.name}</a>)}
        </div>
      </section>
    </main>
  </body>
</html>
