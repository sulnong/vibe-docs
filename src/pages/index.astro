---
const topics = [
  {
    name: 'Astro',
    description: 'A practical bilingual guide for learning Astro, routing, components, content collections, styling, and deployment.',
    en: '/en/astro/',
    zh: '/zh/astro/',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Topics</title>
    <meta name="description" content="A lightweight index of available documentation topics." />
    <style>
      :root {
        color-scheme: light dark;
        font-family: Inter, ui-sans-serif, system-ui, sans-serif;
        background: #0b1018;
        color: #eef4ff;
      }

      body {
        margin: 0;
      }

      main {
        width: min(880px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 64px 0;
      }

      h1 {
        font-size: clamp(2.2rem, 8vw, 4.5rem);
        letter-spacing: 0;
        line-height: 1;
        margin: 0 0 16px;
      }

      .topic-card {
        border: 1px solid rgba(160, 185, 220, 0.24);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.04);
        padding: 24px;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 18px;
      }

      a {
        border: 1px solid rgba(190, 210, 240, 0.28);
        border-radius: 999px;
        color: #eef4ff;
        padding: 10px 14px;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Documentation Topics</h1>
      <p>Choose a topic and language. More topics will be added after they pass editorial review.</p>
      {topics.map((topic) => (
        <article class="topic-card">
          <h2>{topic.name}</h2>
          <p>{topic.description}</p>
          <div class="actions">
            <a href={topic.en}>English</a>
            <a href={topic.zh}>中文</a>
          </div>
        </article>
      ))}
    </main>
  </body>
</html>
